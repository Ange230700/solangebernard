{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SolangeBernard Desktop",
  "version": "0.1.0",
  "identifier": "com.example.solangebernard.desktop",
  "build": {
    "frontendDist": "../dist/desktop/browser",
    "devUrl": "http://127.0.0.1:4201",
    "beforeDevCommand": "pnpm run serve:desktop",
    "beforeBuildCommand": "pnpm exec ng build desktop"
  },
  "app": {
    "windows": [
      {
        "title": "SolangeBernard Desktop",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
