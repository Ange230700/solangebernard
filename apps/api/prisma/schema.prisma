generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AdminRole {
  staff
  admin
}

enum ProductStatus {
  Draft
  Published
}

enum OrderStatus {
  PendingConfirmation
  Confirmed
  ReadyForDelivery
  Delivered
  Cancelled
}

model AdminUser {
  id                     String                @id @default(cuid())
  email                  String                @unique
  passwordHash           String
  role                   AdminRole
  isActive               Boolean               @default(true)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  sessions               AdminSession[]
  passwordResetTokens    PasswordResetToken[]
  inventoryAdjustments   InventoryAdjustment[]
  triggeredNotifications Notification[]        @relation("NotificationOperator")

  @@map("admins")
}

model AdminSession {
  id            String    @id @default(cuid())
  adminUserId   String
  tokenHash     String    @unique
  expiresAt     DateTime
  invalidatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  adminUser     AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId, invalidatedAt])
  @@index([expiresAt])
  @@map("admin_sessions")
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  adminUserId String
  tokenHash   String    @unique
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId, consumedAt])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Product {
  id                   String                @id @default(cuid())
  name                 String
  description          String?
  category             String?
  priceAmount          Int?
  status               ProductStatus         @default(Draft)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  variants             ProductVariant[]
  media                ProductMedia[]
  inventoryAdjustments InventoryAdjustment[]
  orderItems           OrderItem[]

  @@index([status, category])
  @@map("products")
}

model ProductVariant {
  id                   String                @id @default(cuid())
  productId            String
  sku                  String                @unique
  size                 String?
  color                String?
  variantLabel         String
  stock                Int                   @default(0)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  product              Product               @relation(fields: [productId], references: [id])
  inventoryAdjustments InventoryAdjustment[]
  orderItems           OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

model ProductMedia {
  id           String   @id @default(cuid())
  productId    String
  url          String
  altText      String?
  isMain       Boolean  @default(false)
  displayOrder Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  product      Product  @relation(fields: [productId], references: [id])

  @@index([productId, isMain])
  @@map("product_media")
}

model InventoryAdjustment {
  id               String         @id @default(cuid())
  productId        String
  productVariantId String
  actorAdminUserId String
  quantityDelta    Int
  reason           String?
  recordedAt       DateTime       @default(now())
  product          Product        @relation(fields: [productId], references: [id])
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  actor            AdminUser      @relation(fields: [actorAdminUserId], references: [id])

  @@index([productId, recordedAt])
  @@index([productVariantId, recordedAt])
  @@map("inventory_adjustments")
}

model Order {
  id               String         @id @default(cuid())
  orderReference   String         @unique
  status           OrderStatus    @default(PendingConfirmation)
  customerFullName String
  customerPhone    String
  deliveryArea     String
  deliveryAddress  String
  internalNotes    String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  items            OrderItem[]
  notifications    Notification[]

  @@index([status])
  @@map("orders")
}

model OrderItem {
  id                   String         @id @default(cuid())
  orderId              String
  productId            String
  productVariantId     String
  productNameSnapshot  String
  variantLabelSnapshot String
  unitPriceAmount      Int
  quantity             Int
  createdAt            DateTime       @default(now())
  order                Order          @relation(fields: [orderId], references: [id])
  product              Product        @relation(fields: [productId], references: [id])
  productVariant       ProductVariant @relation(fields: [productVariantId], references: [id])

  @@index([orderId])
  @@index([productVariantId])
  @@map("order_items")
}

model Notification {
  id                     String                @id @default(cuid())
  orderId                String
  relatedOrderStatus     OrderStatus?
  triggerEvent           String
  /// Notification status stays string-based until the repo freezes the full
  /// notification lifecycle vocabulary.
  status                 String
  /// Channel stays string-based so the persisted model can keep working beyond
  /// the MVP-first SMS choice frozen in docs/customer-notification-rules.md.
  channel                String?
  recipientName          String
  recipientPhone         String
  triggeredByAdminUserId String?
  queuedAt               DateTime              @default(now())
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  order                  Order                 @relation(fields: [orderId], references: [id])
  triggeredBy            AdminUser?            @relation("NotificationOperator", fields: [triggeredByAdminUserId], references: [id])
  attempts               NotificationAttempt[]

  @@index([orderId])
  @@index([status, queuedAt])
  @@map("notifications")
}

model NotificationAttempt {
  id                   String       @id @default(cuid())
  notificationId       String
  outcome              String
  providerReference    String?
  providerResponseCode String?
  providerMessage      String?
  attemptedAt          DateTime     @default(now())
  notification         Notification @relation(fields: [notificationId], references: [id])

  @@index([notificationId, attemptedAt])
  @@map("notification_attempts")
}
