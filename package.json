{
  "name": "solangebernard",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "client:web": "pnpm --dir apps/client run serve:web",
    "client:mobile": "pnpm --dir apps/client run serve:mobile",
    "client:desktop": "pnpm --dir apps/client run tauri:dev",
    "api": "pnpm --dir apps/api run dev",
    "dev": "pnpm -r --if-present dev",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "commitlint": "commitlint",
    "commitlint:last": "commitlint --from HEAD~1 --to HEAD"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0"
  }
}
