{
  "name": "solangebernard",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "client:web": "pnpm --dir apps/client run serve:web",
    "client:mobile": "pnpm --dir apps/client run serve:mobile",
    "client:desktop": "pnpm --dir apps/client run tauri:dev",
    "api": "pnpm --dir apps/api run dev",
    "db:dev:up": "node scripts/docker-db-up.mjs",
    "db:dev:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:push": "pnpm db:dev:up && pnpm --dir apps/api run prisma:push",
    "db:seed": "pnpm db:push && pnpm --dir apps/api run prisma:seed",
    "dev": "pnpm -r --if-present dev",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm --dir apps/client run lint && pnpm --dir apps/api run lint && pnpm exec eslint . --max-warnings 0",
    "lint:fix": "pnpm --dir apps/client run lint:fix && pnpm --dir apps/api run lint:fix && pnpm exec eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:client:web": "pnpm --dir apps/client run test:web",
    "test:client:desktop": "pnpm --dir apps/client run test:desktop",
    "test:client:mobile": "pnpm --dir apps/client run test:mobile",
    "test:client": "pnpm --dir apps/client run test",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "commitlint": "commitlint",
    "commit": "git-cz",
    "commitlint:last": "commitlint --from HEAD~1 --to HEAD",
    "branch:check": "validate-branch-name",
    "save": "pnpm format && git add . && pnpm commit && git push origin HEAD",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "validate-branch-name": {
    "pattern": "^(main|develop|(feat|fix|chore|docs|test|refactor|ci|style|perf|revert)\\/[a-z0-9]+(?:-[a-z0-9]+)*)$",
    "errorMsg": "Invalid branch name. Use main, develop, or type/short-description. Example: feat/web-homepage"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "husky": "9.1.7",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.1",
    "validate-branch-name": "1.3.2"
  }
}
